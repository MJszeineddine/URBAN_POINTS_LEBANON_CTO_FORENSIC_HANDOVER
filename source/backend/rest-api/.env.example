# Node Environment
NODE_ENV=production
PORT=3000

# Database Configuration (PostgreSQL)
# Use a secure connection string from your secret manager or CI env
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# JWT Configuration
# Provide a strong, random secret via environment/secret manager
JWT_SECRET=CHANGE_ME_SECURE_RANDOM
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Security
BCRYPT_ROUNDS=12
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Lebanon Configuration
TIMEZONE=Asia/Beirut
COUNTRY_CODE=LB
PHONE_CODE=+961
CURRENCY_PRIMARY=LBP
CURRENCY_SECONDARY=USD

# Feature Flags
PAYMENTS_ENABLED=false
STRIPE_ENABLED=false
NOTIFICATIONS_ENABLED=true
GIFTS_ENABLED=true

# BOGOF Configuration
BOGOF_MIN_PARTY_SIZE=2
BOGOF_MAX_PARTY_SIZE=8
BLACKOUT_DATES=2025-01-01,2025-03-30,2025-04-18,2025-04-21,2025-05-01,2025-08-15,2025-11-22

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/urban-points.log

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# API Documentation
API_TITLE=Urban Points Lebanon API
API_VERSION=1.0.0
API_DESCRIPTION=Production API for Urban Points Lebanon - BOGOF Voucher System

# Server Configuration
REQUEST_TIMEOUT_MS=30000
MAX_REQUEST_SIZE=10mb

# Health Check
HEALTH_CHECK_ENDPOINT=/api/health
